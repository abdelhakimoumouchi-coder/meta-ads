# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to authenticate Vercel Cron requests (must be long & random)
CRON_SECRET=replace_me_with_a_long_random_secret

# ─── Meta App Credentials ─────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# Long-lived system-user token (never-expiring recommended for server use)
META_ACCESS_TOKEN=
META_API_VERSION=v23.0

# ─── Meta Ad Account ──────────────────────────────────────────────────────────
# Must include the "act_" prefix  e.g. act_1234567890
META_AD_ACCOUNT_ID=act_
META_BUSINESS_ID=
META_PAGE_ID=
META_INSTAGRAM_ID=
META_PIXEL_ID=

# ─── Campaign / Ad Entity IDs ─────────────────────────────────────────────────
META_CAMPAIGN_ID=
# Comma-separated list of ad-set IDs that belong to this campaign
META_ADSET_IDS=
# Comma-separated list of ad IDs to track (one per creative)
META_AD_IDS=

# ─── Budget Rules (USD) ───────────────────────────────────────────────────────
# Total money allocated for the entire campaign
TOTAL_CAMPAIGN_BUDGET=180
# Number of days the campaign runs
CAMPAIGN_DURATION_DAYS=6
# Target spend per day across all ads
BASE_DAILY_BUDGET=30
# Initial per-ad daily allocation (comma-separated, must sum to BASE_DAILY_BUDGET)
INITIAL_SPLIT=10,10,10

# ─── Optimization Rules ───────────────────────────────────────────────────────
# Minimum hours between two consecutive reallocations
MIN_REALLOCATION_INTERVAL_HOURS=48
# Minimum USD spent by an ad before its performance can influence reallocation
MIN_SPEND_BEFORE_DECISION=8
# Maximum percentage of daily budget that can be shifted in one reallocation
MAX_SINGLE_SHIFT_PERCENT=25
# Minimum daily USD budget allowed for any single ad
MIN_AD_DAILY_BUDGET=5
# Maximum daily USD budget allowed for any single ad
MAX_AD_DAILY_BUDGET=20

# ─── Safety / Pacing ──────────────────────────────────────────────────────────
# Tolerated over-spend percentage before safety actions trigger (e.g. 8 = 8 %)
OVERSPEND_BUFFER_PERCENT=8
# Automatically pause all ads when total budget is exhausted
AUTO_PAUSE_IF_BUDGET_REACHED=true
# Automatically pause all ads when campaign end date is reached
AUTO_PAUSE_IF_CAMPAIGN_END_REACHED=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db
